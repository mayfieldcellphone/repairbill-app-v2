rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Admin check: verified via the /admins collection
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); 
    }

    // Fetch user profile status
    function getUserStatus(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.status;
    }

    function isActive() {
      return isSignedIn() && getUserStatus(request.auth.uid) == 'active';
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // --- User Profiles ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['email', 'role', 'status', 'createdAt']) &&
               data.email is string && data.email.size() <= 256 &&
               data.role in ['admin', 'user'] &&
               data.status in ['pending', 'active', 'suspended'] &&
               data.createdAt is string;
      }

      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      // Allow creation of first profile
      allow create: if isOwner(userId) && 
                      request.resource.data.status == (request.resource.data.email == 'mayfieldcellphonerepairs@gmail.com' ? 'active' : 'pending') &&
                      request.resource.data.role == (request.resource.data.email == 'mayfieldcellphonerepairs@gmail.com' ? 'admin' : 'user') &&
                      isValidUser(request.resource.data);
      
      // Only admins can update status/role. Users can perhaps update displayName/photoURL.
      allow update: if (isAdmin() && isValidUser(request.resource.data)) ||
                      (isOwner(userId) && 
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL']) &&
                       isValidUser(request.resource.data));
                       
      allow delete: if isAdmin();

      // --- Sub-collections for Active Users ---
      match /settings/current {
        allow read, write: if isOwner(userId) && isActive();
      }
      
      match /invoices/{invoiceId} {
        allow read, write: if isOwner(userId) && isActive() && isValidId(invoiceId);
      }
      
      match /expenses/{expenseId} {
        allow read, write: if isOwner(userId) && isActive() && isValidId(expenseId);
      }
      
      match /brands/{brandId} {
        allow read, write: if isOwner(userId) && isActive() && isValidId(brandId);
      }
      
      match /customers/{customerId} {
        allow read, write: if isOwner(userId) && isActive() && isValidId(customerId);
      }
      
      match /suppliers/{supplierId} {
        allow read, write: if isOwner(userId) && isActive() && isValidId(supplierId);
      }
      
      match /leads/{leadId} {
        allow read, write: if isOwner(userId) && isActive() && isValidId(leadId);
      }
    }

    // --- Admins Collection ---
    match /admins/{adminId} {
      allow read: if isSignedIn();
      // Only the code/backend (or a master admin) can write to this.
      // In this setup, we'll allow an admin to manage other admins or the code handles first one.
      allow write: if isAdmin();
    }
  }
}
